generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Quiz {
  id        Int       @id @default(autoincrement())
  question  String
  answer    String
  date      DateTime  @default(now())
  keywords  Keyword[]

  @@map("quizes")
}

model Keyword {
  id      Int    @id @default(autoincrement())
  name    String @unique
  quizes Quiz[]

  @@map("keywords")
}
